{
  "productName": "daily-planner",
  "version": "0.3.5",
  "identifier": "com.dailyplanner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Daily Planner",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "label": "main",
        "url": "index.html",
        "visible": true
      },
      {
        "title": "Floating",
        "width": 300,
        "height": 184,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "label": "floating",
        "url": "/?view=floating",
        "visible": false
      },
      {
        "title": "Floating Settings",
        "width": 440,
        "height": 420,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "label": "floating-settings",
        "url": "/?view=floating-settings",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA0MENCODdBOTI5M0MwRUYKUldUdndKT1NlcmdNQkhWczNKWSsxNTFsTlNGeU5vQlg0aWZMbWFNMnRSaUtEVFh4VEhHeXloVkcK",
      "endpoints": [
        "https://github.com/lqf0624/daily-planner/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg"],
    "category": "Productivity",
    "copyright": "Copyright © 2026 lqf0624",
    "shortDescription": "A smart daily planner with AI support",
    "macOS": {
      "infoPlist": "Info.plist",
      "files": {
        "Resources/icon.icns": "icons/icon.icns"
      }
    },
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../public/tray-work-mac.png",
      "../public/tray-rest-mac.png",
      "../public/sounds"
    ]
  }
}
