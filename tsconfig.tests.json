{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": ".test-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx"
  },
  "include": [
    "tests/**/*.d.ts",
    "tests/**/*.ts",
    "src/stores/migrations.ts",
    "src/utils/taskActivity.ts",
    "src/types/index.ts"
  ]
}
